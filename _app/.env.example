# =============================================================================
# Vitrine Virtual — variáveis de ambiente (template)
# Copie: cp .env.example .env.local  (Mac/Linux)
#        copy .env.example .env.local (Windows)
#
# A app sobe MESMO com .env.local mínimo (só os obrigatórios abaixo).
# As features que dependem de variáveis opcionais ficam desabilitadas com
# mensagem clara — nada de crash em runtime.
# =============================================================================

# =============================================================================
# 🔴 OBRIGATÓRIOS — sem esses 3, a app não sobe
# =============================================================================

# Pegue em: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://tfylrbxajzmhsdnynpbx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# CRÍTICO: nunca expor no front~. Só em rotas server-side.
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# 🟡 RECOMENDADO em desenvolvimento — sem isso, salt fallback de DEV é usado
#                                       (NÃO subir pra produção sem isso)
# =============================================================================

# LGPD — usado para hashear IPs antes de logar (try-on)
# Gere com: openssl rand -hex 32
IP_HASH_SALT=

# E-mails autorizados a acessar /admin/super (lista separada por vírgula)
# Sem isso, ninguém é super-admin via whitelist (só via role direto na tabela profiles)
SUPER_ADMIN_EMAILS=francisco.efjr@gmail.com

# URL pública do app (sem barra no final)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# 🟢 OPCIONAIS — features que ficam desabilitadas sem isso
# =============================================================================

# --- Provador IA (sem isso, o botão "Provar" retorna erro 502) ---
# Ordem de prioridade: Nano Banana → FASHN → Replicate
# Só os providers com key configurada são tentados.

# -----------------------------------------------------------------------------
# Provador IA — FASHN.ai (fallback especializado fashion)
# -----------------------------------------------------------------------------
# https://fashn.ai/api — crie conta e gere uma API key
FASHN_API_KEY=
FASHN_API_BASE_URL=https://api.fashn.ai/v1

# -----------------------------------------------------------------------------
# Provador IA — Google AI / Gemini Nano Banana (primário)
# -----------------------------------------------------------------------------
# Crie a chave em Google AI Studio: https://aistudio.google.com/app/apikey
# Docs oficiais:
# - chaves: https://ai.google.dev/gemini-api/docs/api-key
# - Nano Banana: https://ai.google.dev/gemini-api/docs/nanobanana
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash-image

# -----------------------------------------------------------------------------
# Provador IA — Replicate (último fallback)
# -----------------------------------------------------------------------------
# https://replicate.com — US$ 5 de créditos iniciais
REPLICATE_API_TOKEN=
REPLICATE_VTON_MODEL=cuuupid/idm-vton:c871bb9b046607b680449ecbae55fd8c6d945e0a1948644bf2361b3d021d3ff4

# --- Rate limit por IP no provador (sem isso, libera + warning) ---
# https://upstash.com — free tier suficiente para o MVP
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- CAPTCHA invisível (sem isso, aceita 'dev-bypass' do front) ---
# https://www.cloudflare.com/products/turnstile/ — grátis
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Super-admin — whitelist de e-mails autorizados
# -----------------------------------------------------------------------------
# Lista separada por vírgula. Quem está aqui PODE acessar /admin/super.
# A verificação ainda é cruzada com role na tabela `profiles` (defesa em profundidade).
SUPER_ADMIN_EMAILS=francisco.efjr@gmail.com

# -----------------------------------------------------------------------------
# LGPD — salt para hashear IPs antes de logar
# -----------------------------------------------------------------------------
# Gere com:  openssl rand -hex 32
# NUNCA logamos IP cru — sempre hash com este salt.
IP_HASH_SALT=

# -----------------------------------------------------------------------------
# Kill switch global do provador IA
# -----------------------------------------------------------------------------
# Teto de gasto mensal em US$
