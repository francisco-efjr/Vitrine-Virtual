# =============================================================================
# Vitrine Virtual — variáveis de ambiente (template)
# Copie este arquivo para .env.local e preencha cada valor.
# NUNCA commitar .env.local no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Obtidos no painel do Supabase (Project Settings > API).
# Em desenvolvimento local, use os valores que `supabase start` imprime.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# CRÍTICO: nunca expor no front. Só em rotas server-side.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Provador IA — FASHN.ai (provedor primário)
# -----------------------------------------------------------------------------
# https://fashn.ai/api — criar conta, comprar US$ 10 de créditos para começar.
FASHN_API_KEY=
FASHN_API_BASE_URL=https://api.fashn.ai/v1

# -----------------------------------------------------------------------------
# Provador IA — Replicate (fallback)
# -----------------------------------------------------------------------------
# https://replicate.com — US$ 5 de créditos iniciais.
REPLICATE_API_TOKEN=
REPLICATE_VTON_MODEL=cuuupid/idm-vton:c871bb9b046607b680449ecbae55fd8c6d945e0a1948644bf2361b3d021d3ff4

# -----------------------------------------------------------------------------
# Upstash Redis — rate limit por IP
# -----------------------------------------------------------------------------
# https://upstash.com — free tier suficiente para o MVP.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Cloudflare Turnstile — CAPTCHA invisível
# -----------------------------------------------------------------------------
# https://www.cloudflare.com/products/turnstile/ — grátis.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Super-admin — whitelist de e-mails autorizados
# -----------------------------------------------------------------------------
# Lista separada por vírgula. Quem está aqui PODE acessar /admin/super.
# A verificação ainda é cruzada com role na tabela `profiles` (defesa em profundidade).
SUPER_ADMIN_EMAILS=francisco.efjr@gmail.com

# -----------------------------------------------------------------------------
# LGPD — salt para hashear IPs antes de logar
# -----------------------------------------------------------------------------
# Gere com:  openssl rand -hex 32
# NUNCA logamos IP cru — sempre hash com este salt.
IP_HASH_SALT=

# -----------------------------------------------------------------------------
# Kill switch global do provador IA
# -----------------------------------------------------------------------------
# Teto de gasto mensal em US$. Atingiu, kill switch é ativado pelo cron.
TRY_ON_MONTHLY_BUDGET_USD=100

# -----------------------------------------------------------------------------
# Sentry (observabilidade) — opcional no início
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# URL pública do app (sem barra no final). Em prod: https://vitrinevirtual.com.br
NEXT_PUBLIC_APP_URL=http://localhost:3000
